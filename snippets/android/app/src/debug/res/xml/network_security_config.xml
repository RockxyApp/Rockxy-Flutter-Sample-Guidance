<?xml version="1.0" encoding="utf-8"?>
<!-- Debug builds only. Do not copy this trust policy into app/src/main. -->
<network-security-config>
  <debug-overrides>
    <trust-anchors>
      <certificates src="user" />
      <certificates src="system" />
    </trust-anchors>
  </debug-overrides>
</network-security-config>
